{
  "name": "my-bot",
  "version": "1.0.0",
  "main": "src/core/index.ts",
  "scripts": {
    "start": "node --no-deprecation dist/core/index.js",
    "dev": "nodemon --exec \"node --no-deprecation -r ts-node/register\" src/core/index.ts",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:all": "concurrently --names \"BOT,DASH\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"npm run dev:dashboard\"",
    "build": "cd dashboard && npm run build && cd .. && tsc",
    "build:bot": "tsc",
    "build:dashboard": "cd dashboard && npm run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "compression": "^1.8.1",
    "discord.js": "^14.25.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jimp": "^0.22.10",
    "minio": "^8.0.7",
    "mongoose": "^9.2.3",
    "node-cron": "^3.0.2",
    "node-fetch": "^2.7.0",
    "pokedex-promise-v2": "^4.2.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
